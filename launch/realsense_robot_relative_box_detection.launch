<launch>
  <arg name="camera" default="camera" />
  <arg name="serial_no" default="" />
  <arg name="device_type" default="" />
  <arg name="color_width" default="-1" />
  <arg name="color_height" default="-1" />
  <arg name="color_fps" default="-1" />
  <arg name="enable_depth" default="true" />
  <arg name="enable_confidence" default="true" />
  <arg name="publish_tf" default="true" />
  <arg name="box_config_file" default="$(find apriltag_box_detection)/config/box.yaml" />
  <arg name="robot_config_file" default="$(find apriltag_box_detection)/config/robot.yaml" />
  <arg name="tag_settings_file" default="$(find apriltag_box_detection)/config/settings.yaml" />
  <arg name="tag_config_file" default="$(find apriltag_box_detection)/config/tags.yaml" />
  <arg name="urdf_file" default="/home/leus/catkin_ws/manta_ws/src/manta_controller/manta_ros_bridge_tutorials/models/MANTA_HR_TAIL.urdf" />
  <arg name="manta_package_root" default="/home/leus/catkin_ws/manta_ws/src/manta_controller" />
  <arg name="root_frame" default="CHASSIS" />
  <arg name="overlay" default="true" />
  <arg name="rviz" default="true" />
  <arg name="rviz_config_file" default="$(find apriltag_box_detection)/rviz/realsense_robot_relative_box_detection.rviz" />

  <env name="ROS_PACKAGE_PATH" value="$(arg manta_package_root):$(optenv ROS_PACKAGE_PATH)" />

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="$(arg camera)" />
    <arg name="serial_no" value="$(arg serial_no)" />
    <arg name="device_type" value="$(arg device_type)" />
    <arg name="enable_color" value="true" />
    <arg name="enable_depth" value="$(arg enable_depth)" />
    <arg name="enable_confidence" value="$(arg enable_confidence)" />
    <arg name="color_width" value="$(arg color_width)" />
    <arg name="color_height" value="$(arg color_height)" />
    <arg name="color_fps" value="$(arg color_fps)" />
    <arg name="publish_tf" value="$(arg publish_tf)" />
  </include>

  <include file="$(find apriltag_box_detection)/launch/robot_relative_box_detection.launch">
    <arg name="image_topic" value="/$(arg camera)/color/image_raw" />
    <arg name="camera_info_topic" value="/$(arg camera)/color/camera_info" />
    <arg name="box_config_file" value="$(arg box_config_file)" />
    <arg name="robot_config_file" value="$(arg robot_config_file)" />
    <arg name="tag_settings_file" value="$(arg tag_settings_file)" />
    <arg name="tag_config_file" value="$(arg tag_config_file)" />
    <arg name="urdf_file" value="$(arg urdf_file)" />
    <arg name="manta_package_root" value="$(arg manta_package_root)" />
    <arg name="root_frame" value="$(arg root_frame)" />
    <arg name="overlay" value="$(arg overlay)" />
  </include>

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="realsense_robot_relative_box_detection_rviz"
        args="-d $(arg rviz_config_file)" />
</launch>
