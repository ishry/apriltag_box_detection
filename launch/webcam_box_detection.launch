<launch>
  <arg name="video_device" default="/dev/video0" />
  <arg name="image_width" default="640" />
  <arg name="image_height" default="480" />
  <arg name="pixel_format" default="yuyv" />
  <arg name="camera_name" default="usb_cam" />
  <arg name="camera_frame_id" default="usb_cam" />
  <arg name="camera_info_url" default="file:///home/leus/.ros/camera_info/usb_cam.yaml" />
  <arg name="box_config_file" default="$(find apriltag_box_detection)/config/box.yaml" />
  <arg name="tag_settings_file" default="$(find apriltag_box_detection)/config/settings.yaml" />
  <arg name="tag_config_file" default="$(find apriltag_box_detection)/config/tags.yaml" />
  <arg name="overlay" default="true" />
  <arg name="rviz" default="true" />

  <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device" value="$(arg video_device)" />
    <param name="image_width" value="$(arg image_width)" />
    <param name="image_height" value="$(arg image_height)" />
    <param name="pixel_format" value="$(arg pixel_format)" />
    <param name="camera_name" value="$(arg camera_name)" />
    <param name="camera_frame_id" value="$(arg camera_frame_id)" />
    <param name="camera_info_url" value="$(arg camera_info_url)" />
  </node>

  <include file="$(find apriltag_box_detection)/launch/box_detection.launch">
    <arg name="image_topic" value="/$(arg camera_name)/image_raw" />
    <arg name="camera_info_topic" value="/$(arg camera_name)/camera_info" />
    <arg name="box_config_file" value="$(arg box_config_file)" />
    <arg name="tag_settings_file" value="$(arg tag_settings_file)" />
    <arg name="tag_config_file" value="$(arg tag_config_file)" />
    <arg name="overlay" value="$(arg overlay)" />
    <arg name="rviz" value="$(arg rviz)" />
  </include>
</launch>
